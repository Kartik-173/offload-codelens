{
  "name": "codelens-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_ENV=production node -r dotenv/config ./bin/www dotenv_config_path=/app/.env",
    "dev": "cross-env NODE_ENV=development nodemon -r dotenv/config ./bin/www dotenv_config_path=.env",
    "init-db": "node -r dotenv/config src/scripts/init-db.js dotenv_config_path=.env",
    "reset-tables": "node -r dotenv/config src/scripts/reset-tables.js dotenv_config_path=.env"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1004.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1004.0",
    "@aws-sdk/client-ec2": "^3.1004.0",
    "@aws-sdk/client-elastic-load-balancing": "^3.1004.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1004.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-ses": "^3.1004.0",
    "@aws-sdk/client-sts": "^3.1004.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.60.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.200.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.202.0",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "adm-zip": "^0.5.16",
    "ajv": "^6.12.3",
    "axios": "^1.13.6",
    "axios-retry": "^3.9.1",
    "bcrypt": "^5.0.0",
    "body-parser": "^1.19.0",
    "cassandra-driver": "^4.7.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.6",
    "cross-env": "^7.0.3",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "lodash": "^4.17.23",
    "multer": "^2.0.2",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "semver": "^7.7.4",
    "simple-git": "^3.32.3",
    "toml": "^3.0.0"
